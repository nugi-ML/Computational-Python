   "source": [
    "# Program for computing the height of a ball in vertical motion\n",
    "\n",
    "v0 = 5      # Initial velocity\n",
    "g = 9.81    # Acceleration of gravity\n",
    "t = 0.6     # Time\n",
    "\n",
    "y = v0*t - 0.5*g*t**2   # Vertical position\n",
    "\n",
    "print(y)"
   ]
  },
